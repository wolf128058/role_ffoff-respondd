#!/usr/bin/env python3
import argparse
import json
import socket
import subprocess
import sys
import time


DEFAULT_ADDRESS = "{{ respondd_healthcheck_address }}"
DEFAULT_EXPECTED_NODE_ID = "{{ respondd_healthcheck_expected_node_id }}"
DEFAULT_INTERFACE = "{{ ff_bridge_interface }}"
DEFAULT_PORT = {{ respondd_healthcheck_port }}
DEFAULT_TIMEOUT = {{ respondd_healthcheck_timeout }}


def log(message):
    print("ext-respondd-healthcheck: " + message, file=sys.stderr)


def query_nodeinfo(interface, address, port, timeout):
    ifindex = socket.if_nametoindex(interface)
    sock = socket.socket(socket.AF_INET6, socket.SOCK_DGRAM)
    sock.settimeout(timeout)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_BINDTODEVICE, interface.encode() + b"\0")
    sock.setsockopt(socket.IPPROTO_IPV6, socket.IPV6_MULTICAST_IF, ifindex)
    sock.bind(("::", 0))
    sock.sendto(b"nodeinfo", (address, port, 0, ifindex))

    deadline = time.monotonic() + timeout
    while True:
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            raise TimeoutError("no nodeinfo response received")
        sock.settimeout(remaining)
        data, _source = sock.recvfrom(65535)
        payload = json.loads(data.decode("utf-8"))
        if isinstance(payload, dict) and payload.get("node_id"):
            return payload


def restart_service(service):
    subprocess.run(["systemctl", "restart", service], check=True)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--address", default=DEFAULT_ADDRESS)
    parser.add_argument("--expected-node-id", default=DEFAULT_EXPECTED_NODE_ID)
    parser.add_argument("--interface", default=DEFAULT_INTERFACE)
    parser.add_argument("--port", default=DEFAULT_PORT, type=int)
    parser.add_argument("--restart-service", default="ext-respondd")
    parser.add_argument("--timeout", default=DEFAULT_TIMEOUT, type=float)
    args = parser.parse_args()

    if not args.expected_node_id:
        log("missing expected node_id")
        return 2

    try:
        nodeinfo = query_nodeinfo(args.interface, args.address, args.port, args.timeout)
    except Exception as exc:
        log(str(exc))
        restart_service(args.restart_service)
        return 1

    actual_node_id = str(nodeinfo.get("node_id", "")).lower()
    expected_node_id = args.expected_node_id.lower()
    if actual_node_id != expected_node_id:
        log("unexpected node_id: got %s, expected %s" % (actual_node_id, expected_node_id))
        restart_service(args.restart_service)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
